<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2012/06/nuspec.xsd">
  <metadata>
    <id>Luolan.QQBot</id>
    <version>1.4.0</version>
    <authors>Luolan</authors>
    <license type="expression">MIT</license>
    <licenseUrl>https://licenses.nuget.org/MIT</licenseUrl>
    <readme>README.md</readme>
    <projectUrl>https://github.com/luolangaga/Luolan.QQBot</projectUrl>
    <description>简洁高效的 QQ 官方机器人 SDK，支持 HTTP API 和 WebSocket 事件，自动 Token 刷新，性能极致优化。内置速率限制器、IHttpClientFactory 支持、增强型命令解析器及丰富的类型转换。</description>
    <releaseNotes>v1.4.0: 核心性能架构优化！新增智能速率限制器、IHttpClientFactory 集成支持、增强型引号命令解析器，并支持 bool/enum/Guid/可空类型等多种参数自动转换。</releaseNotes>
    <tags>qq bot qqbot qq-bot qq-robot tencent sdk qq-official-bot markdown websocket ratelimiter httpclientfactory</tags>
    <repository type="git" url="https://github.com/luolangaga/Luolan.QQBot" commit="a319cad9b1e94765a6db8af603b883a88e841b4a" />
    <dependencies>
      <group targetFramework="net8.0">
        <dependency id="Microsoft.Extensions.DependencyInjection.Abstractions" version="10.0.1" exclude="Build,Analyzers" />
        <dependency id="Microsoft.Extensions.Hosting.Abstractions" version="10.0.1" exclude="Build,Analyzers" />
        <dependency id="Microsoft.Extensions.Http" version="10.0.1" exclude="Build,Analyzers" />
        <dependency id="Microsoft.Extensions.Logging.Abstractions" version="10.0.1" exclude="Build,Analyzers" />
        <dependency id="Microsoft.Extensions.Options" version="10.0.1" exclude="Build,Analyzers" />
        <dependency id="System.Text.Json" version="10.0.1" exclude="Build,Analyzers" />
      </group>
    </dependencies>
